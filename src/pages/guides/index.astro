---
const pageTitle = "KungfuWorld | Kung Fu Guides";
const pageDescription =
  "Explore beginner-friendly kung fu guides, training advice, and practical learning paths for Chinese martial arts.";

const heroSection = {
  title: "Learn Kung Fu Step by Step",
  description:
    "Explore beginner guides, training advice, and practical learning paths for Chinese martial arts.",
  primaryCta: {
    label: "Start with Beginner Guides",
    href: "#beginner-guides",
  },
  secondaryCta: {
    label: "Explore Styles",
    href: "/styles",
  },
};

const guideCategories = [
  {
    title: "Beginner Guides",
    description:
      "Clear starting points for readers who are new to kung fu and want a simple introduction.",
    href: "/guides/how-to-start-learning-kung-fu",
  },
  {
    title: "Related Style",
    description:
      "Move from beginner learning into a real style page and understand a concrete martial arts system.",
    href: "/styles/what-is-shaolin-kung-fu",
  },
  {
    title: "Related Master",
    description:
      "Connect practical learning with an important figure in Chinese martial arts history.",
    href: "/masters/ip-man",
  },
];

const featuredGuides = [
  {
    title: "How to Start Learning Kung Fu",
    description:
      "A simple beginner guide to starting kung fu, choosing a style, and building a strong foundation.",
    href: "/guides/how-to-start-learning-kung-fu",
    tag: "Getting Started",
  },
];

const learningPaths = [
  {
    title: "I am completely new to kung fu",
    description:
      "Start with a beginner-friendly guide and understand the first steps clearly.",
    href: "/guides/how-to-start-learning-kung-fu",
  },
  {
    title: "I want to explore a style next",
    description:
      "After the basics, move into a real style page and see how kung fu systems differ.",
    href: "/styles/what-is-shaolin-kung-fu",
  },
  {
    title: "I want cultural context too",
    description:
      "Go deeper into the meaning of kung fu through culture, discipline, and philosophy.",
    href: "/culture/what-does-kung-fu-mean",
  },
];

const relatedTopics = [
  {
    title: "Explore Kung Fu Styles",
    href: "/styles/what-is-shaolin-kung-fu",
  },
  {
    title: "Meet Famous Masters",
    href: "/masters/ip-man",
  },
  {
    title: "Learn the Cultural Background",
    href: "/culture/what-does-kung-fu-mean",
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={pageDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
  </head>

  <body>
    <header class="site-header">
      <div class="container nav">
        <a href="/" class="logo">KungfuWorld</a>

        <nav class="menu">
          <a href="/">Home</a>
          <a href="/styles">Styles</a>
          <a href="/masters">Masters</a>
          <a href="/guides" class="active">Guides</a>
          <a href="/culture">Culture</a>
          <a href="/blog">Blog</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="hero-overlay"></div>
        <div class="container hero-content">
          <p class="eyebrow">Guides</p>
          <h1>{heroSection.title}</h1>
          <p class="hero-text">{heroSection.description}</p>
          <div class="hero-actions">
            <a class="btn btn-primary" href={heroSection.primaryCta.href}>
              {heroSection.primaryCta.label}
            </a>
            <a class="btn btn-secondary" href={heroSection.secondaryCta.href}>
              {heroSection.secondaryCta.label}
            </a>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="container">
          <div class="section-head">
            <p class="section-kicker">Overview</p>
            <h2>Find the right learning path</h2>
            <p>
              This page works as a practical guide hub so readers can move from first questions to real learning steps more easily.
            </p>
          </div>

          <div class="grid grid-3">
            {guideCategories.map((item) => (
              <a class="info-card" href={item.href}>
                <h3>{item.title}</h3>
                <p>{item.description}</p>
                <span class="text-link">Explore →</span>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="section section-soft" id="beginner-guides">
        <div class="container">
          <div class="section-head section-head-inline">
            <div>
              <p class="section-kicker">Featured Guide</p>
              <h2>Start with a real beginner article</h2>
            </div>
            <a class="text-link" href="/styles/what-is-shaolin-kung-fu">
              Explore style page →
            </a>
          </div>

          <div class="grid grid-1">
            {featuredGuides.map((guide) => (
              <article class="guide-card">
                <div class="guide-body">
                  <span class="guide-tag">{guide.tag}</span>
                  <h3>
                    <a href={guide.href}>{guide.title}</a>
                  </h3>
                  <p>{guide.description}</p>
                  <a class="text-link" href={guide.href}>Read guide →</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section">
        <div class="container two-col">
          <div class="content-box">
            <p class="section-kicker">Learning Paths</p>
            <h2>Choose where to begin</h2>
            <p class="box-text">
              These pathways help first-time visitors move from curiosity to deeper exploration without feeling lost.
            </p>

            <div class="link-list">
              {learningPaths.map((item) => (
                <a href={item.href} class="list-link">
                  <div class="list-copy">
                    <strong>{item.title}</strong>
                    <span>{item.description}</span>
                  </div>
                  <span>→</span>
                </a>
              ))}
            </div>
          </div>

          <div class="content-box">
            <p class="section-kicker">Related Topics</p>
            <h2>Connect guides to the rest of the site</h2>
            <p class="box-text">
              Strong internal linking makes your site easier to navigate and helps search engines understand topic relationships.
            </p>

            <div class="link-list">
              {relatedTopics.map((item) => (
                <a href={item.href} class="list-link">
                  <span>{item.title}</span>
                  <span>→</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="container intro-box">
          <p class="section-kicker">About This Topic</p>
          <h2>Why guide pages matter</h2>
          <p>
            Guide pages are one of the most useful parts of a martial arts website. They help beginners understand unfamiliar terms, compare learning paths,
            and make better decisions about where to start.
          </p>
          <p>
            Over time, this page can grow into a stronger hub for beginner guides, comparison articles, training advice, and decision-focused content that
            connects naturally to your styles, masters, and culture sections.
          </p>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div>
          <a href="/" class="logo">KungfuWorld</a>
          <p class="footer-text">
            Explore Chinese kung fu styles, masters, beginner guides, and traditional martial arts culture.
          </p>
        </div>

        <div class="footer-links">
          <a href="/styles">Styles</a>
          <a href="/masters">Masters</a>
          <a href="/guides">Guides</a>
          <a href="/culture">Culture</a>
          <a href="/blog">Blog</a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  :root {
    --bg: #f7f3ee;
    --surface: #ffffff;
    --surface-soft: #f1ebe4;
    --text: #1f1a17;
    --muted: #6f655d;
    --line: rgba(31, 26, 23, 0.08);
    --radius: 24px;
    --shadow: 0 10px 30px rgba(20, 16, 12, 0.06);
    --max-width: 1200px;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: var(--text);
    background: var(--bg);
    line-height: 1.6;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .container {
    width: min(var(--max-width), calc(100% - 32px));
    margin: 0 auto;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(12px);
    background: rgba(247, 243, 238, 0.78);
    border-bottom: 1px solid var(--line);
  }

  .nav {
    min-height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .logo {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .menu {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }

  .menu a {
    color: var(--muted);
    font-size: 0.95rem;
  }

  .menu a.active,
  .menu a:hover {
    color: var(--text);
  }

  .hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    align-items: center;
    background-image: url("https://images.unsplash.com/photo-1517836357463-d25dfeac3438?auto=format&fit=crop&w=1600&q=80");
    background-size: cover;
    background-position: center;
    overflow: hidden;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right, rgba(18, 14, 10, 0.72), rgba(18, 14, 10, 0.25)),
      linear-gradient(to top, rgba(18, 14, 10, 0.16), transparent);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    color: white;
    padding: 84px 0;
    max-width: 760px;
  }

  .eyebrow,
  .section-kicker {
    margin: 0 0 12px;
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.9;
  }

  .hero h1 {
    margin: 0;
    font-size: clamp(2.4rem, 6vw, 4.6rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .hero-text {
    margin-top: 18px;
    max-width: 620px;
    font-size: 1.08rem;
    color: rgba(255, 255, 255, 0.9);
  }

  .hero-actions {
    margin-top: 28px;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 20px;
    border-radius: 999px;
    font-weight: 600;
    transition: 0.2s ease;
    border: 1px solid transparent;
  }

  .btn-primary {
    background: #fff;
    color: #111;
  }

  .btn-secondary {
    background: transparent;
    color: #fff;
    border-color: rgba(255, 255, 255, 0.4);
  }

  .section {
    padding: 88px 0;
  }

  .section-soft {
    background: var(--surface-soft);
  }

  .section-head {
    max-width: 760px;
    margin-bottom: 32px;
  }

  .section-head h2 {
    margin: 0 0 12px;
    font-size: clamp(1.9rem, 4vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .section-head p {
    margin: 0;
    color: var(--muted);
  }

  .section-head-inline {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 16px;
    max-width: unset;
  }

  .grid {
    display: grid;
    gap: 24px;
  }

  .grid-1 {
    grid-template-columns: 1fr;
  }

  .grid-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .info-card,
  .guide-card,
  .content-box,
  .intro-box {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  .info-card,
  .content-box,
  .intro-box {
    padding: 28px;
  }

  .guide-card {
    padding: 0;
  }

  .guide-body {
    padding: 24px;
  }

  .info-card h3,
  .guide-body h3,
  .content-box h2,
  .intro-box h2 {
    margin: 0 0 12px;
    line-height: 1.2;
  }

  .info-card p,
  .guide-body p,
  .box-text,
  .intro-box p,
  .footer-text {
    margin: 0;
    color: var(--muted);
  }

  .text-link {
    display: inline-block;
    margin-top: 14px;
    font-weight: 600;
  }

  .guide-tag {
    display: inline-flex;
    margin-bottom: 12px;
    padding: 6px 10px;
    border-radius: 999px;
    background: var(--surface-soft);
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 600;
  }

  .two-col {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }

  .link-list {
    display: grid;
    gap: 14px;
    margin-top: 20px;
  }

  .list-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 20px;
    border-radius: 18px;
    background: var(--surface-soft);
    border: 1px solid var(--line);
    font-weight: 600;
  }

  .list-copy {
    display: grid;
    gap: 4px;
  }

  .list-copy strong {
    font-size: 0.98rem;
  }

  .list-copy span {
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 400;
  }

  .intro-box {
    max-width: 900px;
  }

  .site-footer {
    padding: 40px 0 56px;
    border-top: 1px solid var(--line);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .footer-links {
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
    align-items: start;
  }

  .footer-links a {
    color: var(--muted);
  }

  @media (max-width: 1024px) {
    .grid-3,
    .two-col {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .menu {
      display: none;
    }

    .section {
      padding: 64px 0;
    }

    .grid-3,
    .two-col {
      grid-template-columns: 1fr;
    }

    .section-head-inline {
      align-items: start;
      flex-direction: column;
    }

    .hero {
      min-height: 54vh;
    }

    .hero-content {
      padding: 72px 0;
    }
  }
</style>