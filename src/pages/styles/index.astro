---
const pageTitle = "KungfuWorld | Kung Fu Styles";
const pageDescription =
  "Explore Chinese kung fu styles and start with a beginner-friendly introduction to Shaolin Kung Fu.";

const heroSection = {
  title: "Explore Chinese Kung Fu Styles",
  description:
    "Discover major Chinese martial arts systems and start with a real beginner-friendly style page.",
  primaryCta: {
    label: "Read Shaolin Guide",
    href: "/styles/what-is-shaolin-kung-fu",
  },
  secondaryCta: {
    label: "Read Beginner Guide",
    href: "/guides/how-to-start-learning-kung-fu",
  },
};

const styleCategories = [
  {
    title: "Featured Style",
    description:
      "Start with a clear introduction to one of the most recognized kung fu traditions.",
    href: "/styles/what-is-shaolin-kung-fu",
  },
  {
    title: "Related Master",
    description:
      "See how style learning connects with a famous martial arts teacher and lineage.",
    href: "/masters/ip-man",
  },
  {
    title: "Related Culture",
    description:
      "Go beyond techniques and understand the deeper meaning behind kung fu practice.",
    href: "/culture/what-does-kung-fu-mean",
  },
];

const styles = [
  {
    title: "What Is Shaolin Kung Fu?",
    description:
      "A beginner-friendly introduction to Shaolin Kung Fu, including its history, training focus, and cultural meaning.",
    href: "/styles/what-is-shaolin-kung-fu",
    tag: "Traditional",
    image:
      "https://images.unsplash.com/photo-1518611012118-696072aa579a?auto=format&fit=crop&w=1200&q=80",
  },
];

const relatedGuides = [
  {
    title: "How to Start Learning Kung Fu",
    href: "/guides/how-to-start-learning-kung-fu",
  },
  {
    title: "Ip Man",
    href: "/masters/ip-man",
  },
  {
    title: "What Does Kung Fu Really Mean?",
    href: "/culture/what-does-kung-fu-mean",
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={pageDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
  </head>

  <body>
    <header class="site-header">
      <div class="container nav">
        <a href="/" class="logo">KungfuWorld</a>

        <nav class="menu">
          <a href="/">Home</a>
          <a href="/styles" class="active">Styles</a>
          <a href="/masters">Masters</a>
          <a href="/guides">Guides</a>
          <a href="/culture">Culture</a>
          <a href="/blog">Blog</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="hero-overlay"></div>
        <div class="container hero-content">
          <p class="eyebrow">Styles</p>
          <h1>{heroSection.title}</h1>
          <p class="hero-text">{heroSection.description}</p>
          <div class="hero-actions">
            <a class="btn btn-primary" href={heroSection.primaryCta.href}>
              {heroSection.primaryCta.label}
            </a>
            <a class="btn btn-secondary" href={heroSection.secondaryCta.href}>
              {heroSection.secondaryCta.label}
            </a>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="container">
          <div class="section-head">
            <p class="section-kicker">Overview</p>
            <h2>Browse style-related entry points</h2>
            <p>
              This page works as a clean style hub and connects readers to real content that already exists.
            </p>
          </div>

          <div class="grid grid-3">
            {styleCategories.map((item) => (
              <a class="info-card" href={item.href}>
                <h3>{item.title}</h3>
                <p>{item.description}</p>
                <span class="text-link">Explore →</span>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="section section-soft">
        <div class="container">
          <div class="section-head section-head-inline">
            <div>
              <p class="section-kicker">Style Library</p>
              <h2>Start with one real style page</h2>
            </div>
            <a class="text-link" href="/guides/how-to-start-learning-kung-fu">
              Beginner guide →
            </a>
          </div>

          <div class="grid grid-1">
            {styles.map((style) => (
              <article class="style-card">
                <a href={style.href} class="style-image-link">
                  <div
                    class="style-image"
                    style={`background-image: url('${style.image}');`}
                  ></div>
                </a>

                <div class="style-body">
                  <span class="style-tag">{style.tag}</span>
                  <h3>
                    <a href={style.href}>{style.title}</a>
                  </h3>
                  <p>{style.description}</p>
                  <a class="text-link" href={style.href}>Read style guide →</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section">
        <div class="container">
          <div class="content-box">
            <p class="section-kicker">Related Reading</p>
            <h2>Keep exploring</h2>
            <p class="box-text">
              Connect style pages with guides, masters, and culture to build a clearer site structure.
            </p>

            <div class="link-list">
              {relatedGuides.map((item) => (
                <a href={item.href} class="list-link">
                  <span>{item.title}</span>
                  <span>→</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div>
          <a href="/" class="logo">KungfuWorld</a>
          <p class="footer-text">
            Explore Chinese kung fu styles, masters, beginner guides, and traditional martial arts culture.
          </p>
        </div>

        <div class="footer-links">
          <a href="/styles">Styles</a>
          <a href="/masters">Masters</a>
          <a href="/guides">Guides</a>
          <a href="/culture">Culture</a>
          <a href="/blog">Blog</a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  :root {
    --bg: #f7f3ee;
    --surface: #ffffff;
    --surface-soft: #f1ebe4;
    --text: #1f1a17;
    --muted: #6f655d;
    --line: rgba(31, 26, 23, 0.08);
    --radius: 24px;
    --shadow: 0 10px 30px rgba(20, 16, 12, 0.06);
    --max-width: 1200px;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: var(--text);
    background: var(--bg);
    line-height: 1.6;
  }
  a { color: inherit; text-decoration: none; }
  .container { width: min(var(--max-width), calc(100% - 32px)); margin: 0 auto; }
  .site-header {
    position: sticky; top: 0; z-index: 20; backdrop-filter: blur(12px);
    background: rgba(247, 243, 238, 0.78); border-bottom: 1px solid var(--line);
  }
  .nav {
    min-height: 72px; display: flex; align-items: center; justify-content: space-between; gap: 24px;
  }
  .logo { font-size: 1.1rem; font-weight: 700; letter-spacing: 0.02em; }
  .menu { display: flex; gap: 24px; flex-wrap: wrap; }
  .menu a { color: var(--muted); font-size: 0.95rem; }
  .menu a.active, .menu a:hover { color: var(--text); }
  .hero {
    position: relative; min-height: 60vh; display: flex; align-items: center;
    background-image: url("https://images.unsplash.com/photo-1518611012118-696072aa579a?auto=format&fit=crop&w=1600&q=80");
    background-size: cover; background-position: center; overflow: hidden;
  }
  .hero-overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(to right, rgba(18, 14, 10, 0.72), rgba(18, 14, 10, 0.25)),
      linear-gradient(to top, rgba(18, 14, 10, 0.16), transparent);
  }
  .hero-content { position: relative; z-index: 1; color: white; padding: 84px 0; max-width: 760px; }
  .eyebrow, .section-kicker {
    margin: 0 0 12px; font-size: 0.82rem; letter-spacing: 0.14em; text-transform: uppercase; opacity: 0.9;
  }
  .hero h1 {
    margin: 0; font-size: clamp(2.4rem, 6vw, 4.6rem); line-height: 1.05; letter-spacing: -0.03em;
  }
  .hero-text {
    margin-top: 18px; max-width: 620px; font-size: 1.08rem; color: rgba(255, 255, 255, 0.9);
  }
  .hero-actions { margin-top: 28px; display: flex; gap: 14px; flex-wrap: wrap; }
  .btn {
    display: inline-flex; align-items: center; justify-content: center; min-height: 48px; padding: 0 20px;
    border-radius: 999px; font-weight: 600; transition: 0.2s ease; border: 1px solid transparent;
  }
  .btn-primary { background: #fff; color: #111; }
  .btn-secondary { background: transparent; color: #fff; border-color: rgba(255, 255, 255, 0.4); }
  .section { padding: 88px 0; }
  .section-soft { background: var(--surface-soft); }
  .section-head { max-width: 760px; margin-bottom: 32px; }
  .section-head h2 {
    margin: 0 0 12px; font-size: clamp(1.9rem, 4vw, 3rem); line-height: 1.1; letter-spacing: -0.03em;
  }
  .section-head p { margin: 0; color: var(--muted); }
  .section-head-inline {
    display: flex; align-items: end; justify-content: space-between; gap: 16px; max-width: unset;
  }
  .grid { display: grid; gap: 24px; }
  .grid-1 { grid-template-columns: 1fr; }
  .grid-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .info-card, .style-card, .content-box {
    background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius); box-shadow: var(--shadow);
  }
  .info-card, .content-box { padding: 28px; }
  .info-card h3, .style-body h3, .content-box h2 { margin: 0 0 12px; line-height: 1.2; }
  .info-card p, .style-body p, .box-text, .footer-text { margin: 0; color: var(--muted); }
  .text-link { display: inline-block; margin-top: 14px; font-weight: 600; }
  .style-card { overflow: hidden; }
  .style-image { aspect-ratio: 4 / 3; background-size: cover; background-position: center; }
  .style-body { padding: 22px; }
  .style-tag {
    display: inline-flex; margin-bottom: 12px; padding: 6px 10px; border-radius: 999px;
    background: var(--surface-soft); color: var(--muted); font-size: 0.82rem; font-weight: 600;
  }
  .link-list { display: grid; gap: 14px; margin-top: 20px; }
  .list-link {
    display: flex; align-items: center; justify-content: space-between; padding: 18px 20px;
    border-radius: 18px; background: var(--surface-soft); border: 1px solid var(--line); font-weight: 600;
  }
  .site-footer { padding: 40px 0 56px; border-top: 1px solid var(--line); }
  .footer-inner { display: flex; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
  .footer-links { display: flex; gap: 18px; flex-wrap: wrap; align-items: start; }
  .footer-links a { color: var(--muted); }
  @media (max-width: 1024px) { .grid-3 { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 720px) {
    .menu { display: none; }
    .section { padding: 64px 0; }
    .grid-3 { grid-template-columns: 1fr; }
    .section-head-inline { align-items: start; flex-direction: column; }
    .hero { min-height: 54vh; }
    .hero-content { padding: 72px 0; }
  }
</style>