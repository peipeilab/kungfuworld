---
const pageTitle = "KungfuWorld | Blog";
const pageDescription =
  "Read the latest articles on Chinese kung fu, martial arts culture, and beginner-friendly topics.";

const heroSection = {
  title: "Read the Latest Kung Fu Articles",
  description:
    "Explore short articles, connected topic pages, and supporting content across the site.",
  primaryCta: {
    label: "Read Latest Post",
    href: "/blog/test-post",
  },
  secondaryCta: {
    label: "Explore Guides",
    href: "/guides/how-to-start-learning-kung-fu",
  },
};

const featuredPosts = [
  {
    title: "Why Kung Fu Still Inspires People Today",
    description:
      "A short article about why kung fu continues to inspire people through movement, culture, and personal growth.",
    href: "/blog/test-post",
    date: "March 12, 2026",
    category: "Blog",
  },
];

const topicLinks = [
  { title: "Styles", href: "/styles/what-is-shaolin-kung-fu" },
  { title: "Masters", href: "/masters/ip-man" },
  { title: "Guides", href: "/guides/how-to-start-learning-kung-fu" },
  { title: "Culture", href: "/culture/what-does-kung-fu-mean" },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={pageDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
  </head>

  <body>
    <header class="site-header">
      <div class="container nav">
        <a href="/" class="logo">KungfuWorld</a>

        <nav class="menu">
          <a href="/">Home</a>
          <a href="/styles">Styles</a>
          <a href="/masters">Masters</a>
          <a href="/guides">Guides</a>
          <a href="/culture">Culture</a>
          <a href="/blog" class="active">Blog</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="hero-overlay"></div>
        <div class="container hero-content">
          <p class="eyebrow">Blog</p>
          <h1>{heroSection.title}</h1>
          <p class="hero-text">{heroSection.description}</p>
          <div class="hero-actions">
            <a class="btn btn-primary" href={heroSection.primaryCta.href}>
              {heroSection.primaryCta.label}
            </a>
            <a class="btn btn-secondary" href={heroSection.secondaryCta.href}>
              {heroSection.secondaryCta.label}
            </a>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="container">
          <div class="section-head">
            <p class="section-kicker">Overview</p>
            <h2>Browse connected topics</h2>
            <p>
              Use the blog as a supporting publishing hub and connect it to your main topic sections.
            </p>
          </div>

          <div class="topic-grid">
            {topicLinks.map((item) => (
              <a class="topic-link" href={item.href}>
                <span>{item.title}</span>
                <span>→</span>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="section section-soft">
        <div class="container">
          <div class="section-head">
            <p class="section-kicker">Latest Post</p>
            <h2>Start with one real article</h2>
            <p>
              As your site grows, this section can expand into multiple posts, categories, and pagination.
            </p>
          </div>

          <div class="grid grid-1">
            {featuredPosts.map((post) => (
              <article class="post-card">
                <div class="post-meta">
                  <span>{post.category}</span>
                  <span>•</span>
                  <time>{post.date}</time>
                </div>

                <h3>
                  <a href={post.href}>{post.title}</a>
                </h3>

                <p>{post.description}</p>
                <a class="text-link" href={post.href}>Read article →</a>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section">
        <div class="container intro-box">
          <p class="section-kicker">About This Section</p>
          <h2>Why the blog matters</h2>
          <p>
            Your blog helps the site stay active and flexible. It gives you space for short articles, updates, reflections, and supporting SEO content.
          </p>
          <p>
            Over time, it can expand into a stronger publishing section connected to your styles, masters, guides, and culture pages.
          </p>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div>
          <a href="/" class="logo">KungfuWorld</a>
          <p class="footer-text">
            Explore Chinese kung fu styles, masters, beginner guides, and traditional martial arts culture.
          </p>
        </div>

        <div class="footer-links">
          <a href="/styles">Styles</a>
          <a href="/masters">Masters</a>
          <a href="/guides">Guides</a>
          <a href="/culture">Culture</a>
          <a href="/blog">Blog</a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  :root {
    --bg: #f7f3ee;
    --surface: #ffffff;
    --surface-soft: #f1ebe4;
    --text: #1f1a17;
    --muted: #6f655d;
    --line: rgba(31, 26, 23, 0.08);
    --radius: 24px;
    --shadow: 0 10px 30px rgba(20, 16, 12, 0.06);
    --max-width: 1200px;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: var(--text);
    background: var(--bg);
    line-height: 1.6;
  }
  a { color: inherit; text-decoration: none; }
  .container { width: min(var(--max-width), calc(100% - 32px)); margin: 0 auto; }
  .site-header {
    position: sticky; top: 0; z-index: 20; backdrop-filter: blur(12px);
    background: rgba(247, 243, 238, 0.78); border-bottom: 1px solid var(--line);
  }
  .nav {
    min-height: 72px; display: flex; align-items: center; justify-content: space-between; gap: 24px;
  }
  .logo { font-size: 1.1rem; font-weight: 700; letter-spacing: 0.02em; }
  .menu { display: flex; gap: 24px; flex-wrap: wrap; }
  .menu a { color: var(--muted); font-size: 0.95rem; }
  .menu a.active, .menu a:hover { color: var(--text); }
  .hero {
    position: relative; min-height: 60vh; display: flex; align-items: center;
    background-image: url("https://images.unsplash.com/photo-1491841550275-ad7854e35ca6?auto=format&fit=crop&w=1600&q=80");
    background-size: cover; background-position: center; overflow: hidden;
  }
  .hero-overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(to right, rgba(18, 14, 10, 0.72), rgba(18, 14, 10, 0.25)),
      linear-gradient(to top, rgba(18, 14, 10, 0.16), transparent);
  }
  .hero-content { position: relative; z-index: 1; color: white; padding: 84px 0; max-width: 760px; }
  .eyebrow, .section-kicker {
    margin: 0 0 12px; font-size: 0.82rem; letter-spacing: 0.14em; text-transform: uppercase; opacity: 0.9;
  }
  .hero h1 {
    margin: 0; font-size: clamp(2.4rem, 6vw, 4.6rem); line-height: 1.05; letter-spacing: -0.03em;
  }
  .hero-text {
    margin-top: 18px; max-width: 620px; font-size: 1.08rem; color: rgba(255, 255, 255, 0.9);
  }
  .hero-actions { margin-top: 28px; display: flex; gap: 14px; flex-wrap: wrap; }
  .btn {
    display: inline-flex; align-items: center; justify-content: center; min-height: 48px; padding: 0 20px;
    border-radius: 999px; font-weight: 600; transition: 0.2s ease; border: 1px solid transparent;
  }
  .btn-primary { background: #fff; color: #111; }
  .btn-secondary { background: transparent; color: #fff; border-color: rgba(255, 255, 255, 0.4); }
  .section { padding: 88px 0; }
  .section-soft { background: var(--surface-soft); }
  .section-head { max-width: 760px; margin-bottom: 32px; }
  .section-head h2 {
    margin: 0 0 12px; font-size: clamp(1.9rem, 4vw, 3rem); line-height: 1.1; letter-spacing: -0.03em;
  }
  .section-head p { margin: 0; color: var(--muted); }
  .topic-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 16px; }
  .topic-link, .post-card, .intro-box {
    background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius); box-shadow: var(--shadow);
  }
  .topic-link {
    display: flex; align-items: center; justify-content: space-between; padding: 20px 22px; font-weight: 600;
  }
  .grid { display: grid; gap: 24px; }
  .grid-1 { grid-template-columns: 1fr; }
  .post-card, .intro-box { padding: 28px; }
  .post-meta {
    display: flex; align-items: center; gap: 8px; margin-bottom: 12px; color: var(--muted); font-size: 0.9rem;
  }
  .post-card h3, .intro-box h2 { margin: 0 0 12px; line-height: 1.2; }
  .post-card p, .intro-box p, .footer-text { margin: 0; color: var(--muted); }
  .text-link { display: inline-block; margin-top: 14px; font-weight: 600; }
  .intro-box { max-width: 900px; }
  .site-footer { padding: 40px 0 56px; border-top: 1px solid var(--line); }
  .footer-inner { display: flex; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
  .footer-links { display: flex; gap: 18px; flex-wrap: wrap; align-items: start; }
  .footer-links a { color: var(--muted); }
  @media (max-width: 1024px) { .topic-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 720px) {
    .menu { display: none; }
    .section { padding: 64px 0; }
    .topic-grid { grid-template-columns: 1fr; }
    .hero { min-height: 54vh; }
    .hero-content { padding: 72px 0; }
  }
</style>