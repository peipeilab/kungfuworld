---
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const items = await getCollection("masters");

  return items.map((item) => ({
    params: {
      slug: item.id.replace(/\.md$/, "").replace(/\.mdx$/, ""),
    },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);

const pageTitle = `${item.data.title} | KungfuWorld`;
const pageDescription = item.data.description;
const publishDate = new Date(item.data.date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={pageDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
  </head>

  <body>
    <header class="site-header">
      <div class="container nav">
        <a href="/" class="logo">KungfuWorld</a>

        <nav class="menu">
          <a href="/">Home</a>
          <a href="/styles">Styles</a>
          <a href="/masters" class="active">Masters</a>
          <a href="/guides">Guides</a>
          <a href="/culture">Culture</a>
          <a href="/blog">Blog</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="post-hero">
        <div class="container post-hero-inner">
          <a href="/masters" class="back-link">← Back to Masters</a>

          <div class="post-meta">
            <span>{item.data.category}</span>
            <span>•</span>
            <time datetime={String(item.data.date)}>{publishDate}</time>
          </div>

          <h1>{item.data.title}</h1>
          <p class="post-description">{item.data.description}</p>

          {item.data.tags && item.data.tags.length > 0 && (
            <div class="tags">
              {item.data.tags.map((tag: string) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </section>

      <section class="post-section">
        <div class="container article-wrap">
          <article class="post-content">
            <Content />
          </article>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div>
          <a href="/" class="logo">KungfuWorld</a>
          <p class="footer-text">
            Explore Chinese kung fu styles, masters, beginner guides, and traditional martial arts culture.
          </p>
        </div>

        <div class="footer-links">
          <a href="/styles">Styles</a>
          <a href="/masters">Masters</a>
          <a href="/guides">Guides</a>
          <a href="/culture">Culture</a>
          <a href="/blog">Blog</a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  :root {
    --bg: #f7f3ee;
    --surface: #ffffff;
    --surface-soft: #f1ebe4;
    --text: #1f1a17;
    --muted: #6f655d;
    --line: rgba(31, 26, 23, 0.08);
    --radius: 24px;
    --shadow: 0 10px 30px rgba(20, 16, 12, 0.06);
    --max-width: 1200px;
    --content-width: 760px;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    margin: 0;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: var(--text);
    background: var(--bg);
    line-height: 1.7;
  }

  a { color: inherit; text-decoration: none; }

  .container {
    width: min(var(--max-width), calc(100% - 32px));
    margin: 0 auto;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(12px);
    background: rgba(247, 243, 238, 0.78);
    border-bottom: 1px solid var(--line);
  }

  .nav {
    min-height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .logo {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .menu {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }

  .menu a {
    color: var(--muted);
    font-size: 0.95rem;
  }

  .menu a.active,
  .menu a:hover {
    color: var(--text);
  }

  .post-hero {
    padding: 72px 0 36px;
  }

  .post-hero-inner {
    max-width: var(--content-width);
  }

  .back-link {
    display: inline-flex;
    margin-bottom: 24px;
    color: var(--muted);
    font-weight: 600;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--muted);
    font-size: 0.95rem;
    margin-bottom: 16px;
  }

  h1 {
    margin: 0 0 16px;
    font-size: clamp(2.2rem, 6vw, 4.2rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
  }

  .post-description {
    margin: 0;
    color: var(--muted);
    font-size: 1.08rem;
    max-width: 680px;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 24px;
  }

  .tag {
    display: inline-flex;
    padding: 7px 12px;
    border-radius: 999px;
    background: var(--surface-soft);
    color: var(--muted);
    font-size: 0.85rem;
    font-weight: 600;
  }

  .post-section {
    padding: 12px 0 88px;
  }

  .article-wrap {
    max-width: var(--content-width);
  }

  .post-content {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 40px 32px;
  }

  :global(.post-content h1),
  :global(.post-content h2),
  :global(.post-content h3) {
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-top: 2em;
    margin-bottom: 0.7em;
  }

  :global(.post-content h1:first-child),
  :global(.post-content h2:first-child),
  :global(.post-content h3:first-child) {
    margin-top: 0;
  }

  :global(.post-content p) {
    margin: 0 0 1.2em;
    color: #2f2925;
  }

  :global(.post-content ul),
  :global(.post-content ol) {
    margin: 0 0 1.4em 1.25em;
    padding: 0;
  }

  :global(.post-content li) {
    margin-bottom: 0.5em;
  }

  :global(.post-content a) {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  :global(.post-content blockquote) {
    margin: 1.5em 0;
    padding: 16px 18px;
    border-left: 4px solid #c9b8a6;
    background: var(--surface-soft);
    border-radius: 12px;
    color: var(--muted);
  }

  :global(.post-content img) {
    width: 100%;
    height: auto;
    display: block;
    margin: 1.5em 0;
    border-radius: 18px;
  }

  :global(.post-content hr) {
    border: 0;
    border-top: 1px solid var(--line);
    margin: 2em 0;
  }

  :global(.post-content code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.92em;
    background: var(--surface-soft);
    padding: 0.18em 0.4em;
    border-radius: 8px;
  }

  :global(.post-content pre) {
    overflow-x: auto;
    padding: 18px;
    background: #1f1a17;
    color: #f8f3ee;
    border-radius: 18px;
    margin: 1.5em 0;
  }

  :global(.post-content pre code) {
    background: transparent;
    padding: 0;
    color: inherit;
  }

  .site-footer {
    padding: 40px 0 56px;
    border-top: 1px solid var(--line);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .footer-text {
    margin: 0;
    color: var(--muted);
  }

  .footer-links {
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
    align-items: start;
  }

  .footer-links a {
    color: var(--muted);
  }

  @media (max-width: 720px) {
    .menu { display: none; }
    .post-hero { padding: 56px 0 28px; }
    .post-section { padding-bottom: 64px; }
    .post-content {
      padding: 28px 20px;
      border-radius: 20px;
    }
  }
</style>